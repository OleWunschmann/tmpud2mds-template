  "type": "PTE",
  "runs-on": "ubuntu-latest",
  "shell": "pwsh",
  "MicrosoftTelemetryConnectionString": "",
  "customALGoFiles": {
    "filesToExclude": [
      {
        "sourceFolder": ".github/workflows",
        "filter": "DeployReferenceDocumentation.yaml"
      }
    ],
    "filesToRemove": [
      {
        "filter": "CustomTemplateFile.Legacy.txt"
      }
